# ============================================================================
# CONTAINER REGISTRY
# ============================================================================
ECR_REGISTRY=123456789012.dkr.ecr.us-east-1.amazonaws.com
ECR_REPOSITORY_FRONTEND=ledgr/frontend
ECR_REPOSITORY_BACKEND=ledgr/backend
