# ============================================================================
# KUBERNETES CONFIGURATION
# ============================================================================
KUBE_CLUSTER_NAME=ledgr-prod
KUBE_REGION=us-east-1
KUBE_NAMESPACE=ledgr
KUBE_CONTEXT=arn:aws:eks:us-east-1:123456789012:cluster/ledgr-prod

# ============================================================================
# MONITORING & OBSERVABILITY
# ============================================================================
# Prometheus
PROMETHEUS_SCRAPE_INTERVAL=15s
PROMETHEUS_RETENTION=30d

# Grafana
GRAFANA_ADMIN_PASSWORD=change_me
GRAFANA_DASHBOARD_URL=https://grafana.ledgr.ai

# Datadog (optional)
DATADOG_API_KEY=change_me
DATADOG_APP_KEY=change_me
DATADOG_SITE=datadoghq.com

# New Relic (optional)
NEW_RELIC_LICENSE_KEY=change_me
NEW_RELIC_APP_NAME=Ledgr

# Sentry (error tracking)
SENTRY_DSN=https://change_me@sentry.io/1234567
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# ============================================================================
# APPLICATION FEATURES
# ============================================================================
# Feature Flags
FEATURE_DEMO_MODE=false
FEATURE_NEW_DASHBOARD=true
FEATURE_ADVANCED_ANALYTICS=true
FEATURE_CUSTOM_BRANDING=true
FEATURE_TEAM_COLLABORATION=true
FEATURE_AUDIT_LOGS=true

# Limits & Quotas
MAX_ACTIVE_AGENTS=10
MAX_TEAM_SIZE=50
MAX_STORAGE_GB=100
MAX_API_CALLS_PER_HOUR=10000
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# ============================================================================
# COMPLIANCE & REGULATORY
# ============================================================================
# UAE Regulatory Compliance
UAE_TAX_ID_REQUIRED=true
VAT_ENABLED=true
VAT_RATE=0.05

# GDPR/CCPA Compliance
DATA_RETENTION_DAYS=1825
GDPR_COMPLIANT=true
CCPA_COMPLIANT=true
SOC2_AUDIT=true

# Encryption
ENCRYPTION_KEY=change_me_32_byte_hex_string
ENCRYPTION_ALGORITHM=aes-256-gcm
ENCRYPTION_IV_LENGTH=16

# ============================================================================
# SUPPORT & HELP CENTRE
# ============================================================================
HELP_CENTRE_ENABLED=true
SUPPORT_EMAIL=support@ledgr.ai
SUPPORT_PHONE=+971-4-xxxx-xxxx
SUPPORT_CHAT_ENABLED=true
SUPPORT_SLA_MINUTES=60

# Knowledge Base
KNOWLEDGE_BASE_URL=https://kb.ledgr.ai
KNOWLEDGE_BASE_SYNC_INTERVAL=3600

# ============================================================================
# DEBUGGING & LOGGING
# ============================================================================
DEBUG=false
LOG_FORMAT=json
LOG_TO_FILE=true
LOG_FILE_PATH=/var/log/ledgr/app.log
LOG_FILE_ROTATE=daily
LOG_FILE_RETENTION_DAYS=30

# Request Logging
LOG_HTTP_REQUESTS=true
LOG_SENSITIVE_DATA=false
LOG_SQL_QUERIES=false

# ============================================================================
# PERFORMANCE TUNING
# ============================================================================
CACHE_TTL_SECONDS=3600
CACHE_MAX_SIZE_MB=512
QUERY_TIMEOUT_MS=5000
INDEXING_BATCH_SIZE=1000
BACKGROUND_QUEUE_WORKERS=4

# ============================================================================
# DEPLOYMENT METADATA
# ============================================================================
DEPLOYMENT_ENV=production
DEPLOYMENT_VERSION=1.0.0
DEPLOYMENT_TIMESTAMP=$(date -u +%Y-%m-%dT%H:%M:%SZ)
GIT_COMMIT_SHA=change_me
GIT_BRANCH=main
BUILD_NUMBER=0
RELEASE_NOTES_URL=https://docs.ledgr.ai/releases/v1.0.0

# ============================================================================
# NOTES FOR PRODUCTION DEPLOYMENT
# ============================================================================
# 1. Generate strong random strings for all SECRET values using:
#    openssl rand -base64 32
#
# 2. Ensure all API keys and credentials are stored in AWS Secrets Manager
#    or similar secure vault, NOT in version control
#
# 3. Enable HTTPS/TLS for all connections (handled by reverse proxy)
#
# 4. Use strong database passwords (20+ characters, mix of types)
#
# 5. Enable CloudTrail logging for all AWS API calls
#
# 6. Set up VPN or IP whitelisting for database access
#
# 7. Configure backup schedules (daily, with 30-day retention)
#
# 8. Set up monitoring alerts for:
#    - High error rates (>1%)
#    - High latency (p95 > 500ms)
#    - CPU usage > 80%
#    - Memory usage > 85%
#    - Disk usage > 90%
#
# 9. Enable WAF (Web Application Firewall) on CloudFront
#
# 10. Configure DDoS protection (AWS Shield Advanced)
# ============================================================================
